# .env.backup — fill in and save as scripts/.env.backup  (this file is gitignored)
#
# Source this before running backup/restore scripts:
#   source scripts/.env.backup && ./scripts/db-dump.sh
#
# Get these URLs from:
#   PostgreSQL → Render dashboard → <database name> → Info → External Database URL
#   MongoDB    → MongoDB Atlas → Connect → Drivers → connection string

# ── PostgreSQL (Render External Database URLs) ───────────────────────────────
export AUDIT_DB_URL="postgres://USER:PASSWORD@RENDER_HOST:5432/DB_NAME"
export HEALTH_DB_URL="postgres://USER:PASSWORD@RENDER_HOST:5432/DB_NAME"
export SOCIAL_DB_URL="postgres://USER:PASSWORD@RENDER_HOST:5432/DB_NAME"

# ── For restore: fill in NEW database URLs after creating fresh Render DBs ───
export NEW_AUDIT_DB_URL="postgres://USER:PASSWORD@NEW_RENDER_HOST:5432/DB_NAME"
export NEW_HEALTH_DB_URL="postgres://USER:PASSWORD@NEW_RENDER_HOST:5432/DB_NAME"
export NEW_SOCIAL_DB_URL="postgres://USER:PASSWORD@NEW_RENDER_HOST:5432/DB_NAME"

# ── MongoDB Atlas ─────────────────────────────────────────────────────────────
export MONGO_URI="mongodb+srv://USERNAME:PASSWORD@cluster.mongodb.net/privacy_audit_ai"
